<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Dpz.ServiceHub.ViewModels"
        mc:Ignorable="d"
        x:Class="Dpz.ServiceHub.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Icon="/Assets/Dpz.ServiceHub.ico"
        Width="520"
        Height="360"
        MinWidth="520"
        MinHeight="360"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="设置">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <TextBlock Grid.Row="0"
                   Text="应用设置"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Spacing="20">
            <!-- 自动检测外部进程 -->
            <StackPanel Spacing="8">
                <CheckBox IsChecked="{Binding AutoDetectExternalProcesses}"
                         Content="自动检测外部进程"
                         FontWeight="SemiBold"/>
                <TextBlock Text="定期扫描并标记在工具外启动的服务进程"
                          Foreground="Gray"
                          FontSize="12"
                          Margin="28,0,0,0"/>
            </StackPanel>

            <!-- 检测间隔 -->
            <StackPanel Spacing="8">
                <TextBlock Text="检测间隔（秒）" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="120,Auto">
                    <NumericUpDown Grid.Column="0"
                                  Value="{Binding DetectionIntervalSeconds}"
                                  Minimum="1"
                                  Maximum="60"
                                  Increment="1"
                                  FormatString="0"
                                  ShowButtonSpinner="True"/>
                    <TextBlock Grid.Column="1"
                              Text="建议 3-5 秒"
                              Foreground="Gray"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- 输出日志保留行数 -->
            <StackPanel Spacing="8">
                <TextBlock Text="输出日志最大行数" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="120,Auto">
                    <NumericUpDown Grid.Column="0"
                                  Value="{Binding MaxOutputLines}"
                                  Minimum="100"
                                  Maximum="10000"
                                  Increment="100"
                                  FormatString="0"
                                  ShowButtonSpinner="True"/>
                    <TextBlock Grid.Column="1"
                              Text="超出将自动截断"
                              Foreground="Gray"
                              FontSize="12"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="12"
                    Margin="0,20,0,0">
            <Button Content="保存" MinWidth="100" Click="OnSaveClick"/>
            <Button Content="取消" MinWidth="100" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
