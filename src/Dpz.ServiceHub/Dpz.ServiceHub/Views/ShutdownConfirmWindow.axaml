<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Dpz.ServiceHub.Views.ShutdownConfirmWindow"
        Icon="/Assets/Dpz.ServiceHub.ico"
        Width="520"
        Height="320"
        MinWidth="520"
        MinHeight="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="关闭确认">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <TextBlock Grid.Row="0"
                   Text="检测到仍有进程内启动的服务正在运行，是否在退出前停止这些服务？"
                   TextWrapping="Wrap"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="6" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBlock Name="ServiceListTextBlock"
                           TextWrapping="Wrap"
                           FontFamily="Consolas,Courier New,monospace"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button Content="停止服务并退出"
                    MinWidth="120"
                    Click="OnStopAndExitClick"/>
            <Button Content="取消"
                    MinWidth="70"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
